---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  role: string;
  year: string;
  tags: string[];
  slug: string;
}

const { title, description, role, year, tags, slug } = Astro.props;

const ogTitle = `${title} — Austin Ban`;
const ogDescription = description;

const caseStudySchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description,
  url: `https://austinban.github.io/portfolio-v2/work/${slug}`,
  author: {
    '@type': 'Person',
    name: 'Austin Ban',
    url: 'https://austinban.github.io/portfolio-v2',
  },
  dateCreated: year,
  keywords: tags.join(', '),
};
---

<Base title={ogTitle} description={ogDescription} ogTitle={ogTitle} ogDescription={ogDescription} ogType="article" schema={caseStudySchema}>

  <div class="min-h-screen bg-dark text-cream font-sans">
    <nav class="fixed top-0 inset-x-0 z-50 flex items-center justify-between px-8 md:px-16 py-6">
      <a href="/portfolio-v2/" class="text-muted text-sm uppercase tracking-widest hover:text-cream transition-colors duration-200">
        ← Back
      </a>
      <span class="text-muted text-sm">{year}</span>
    </nav>

    <main class="pt-32 pb-24 px-8 md:px-20 max-w-3xl mx-auto">
      <div class="flex gap-2 flex-wrap mb-6">
        {tags.map(tag => (
          <span class="text-xs uppercase tracking-widest text-muted border border-muted/30 px-3 py-1">{tag}</span>
        ))}
      </div>

      <h1 class="text-5xl md:text-7xl font-bold text-cream leading-none mb-4">{title}</h1>
      <p class="text-xl text-muted font-light mb-2">{description}</p>
      <p class="text-sm text-muted/60 uppercase tracking-widest mb-16">Role: {role}</p>

      <div class="prose-custom">
        <slot />
      </div>
    </main>
  </div>
</Base>

<style>
  .prose-custom :global(h2) {
    margin-top: 3rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    color: #7a7060;
    font-weight: 700;
  }

  .prose-custom :global(p) {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #a09880;
    margin-bottom: 1.25rem;
    font-weight: 300;
  }
</style>
