---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  role: string;
  year: string;
  tags: string[];
}

const { title, description, role, year, tags } = Astro.props;
---

<Base title={`${title} — Austin Ban`}>
  <div class="min-h-screen bg-dark text-cream font-sans">
    <nav class="fixed top-0 inset-x-0 z-50 flex items-center justify-between px-8 md:px-16 py-6">
      <a href="/" class="text-muted text-sm uppercase tracking-widest hover:text-cream transition-colors duration-200">
        ← Back
      </a>
      <span class="text-muted text-sm">{year}</span>
    </nav>

    <main class="pt-32 pb-24 px-8 md:px-20 max-w-3xl mx-auto">
      <div class="flex gap-2 flex-wrap mb-6">
        {tags.map(tag => (
          <span class="text-xs uppercase tracking-widest text-muted border border-muted/30 px-3 py-1">{tag}</span>
        ))}
      </div>

      <h1 class="text-5xl md:text-7xl font-bold text-cream leading-none mb-4">{title}</h1>
      <p class="text-xl text-muted font-light mb-2">{description}</p>
      <p class="text-sm text-muted/60 uppercase tracking-widest mb-16">Role: {role}</p>

      <div class="prose-custom">
        <slot />
      </div>
    </main>
  </div>
</Base>

<style>
  .prose-custom :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fffbf0;
    margin-top: 3rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    color: #7a7060;
  }

  .prose-custom :global(p) {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #a09880;
    margin-bottom: 1.25rem;
    font-weight: 300;
  }
</style>
