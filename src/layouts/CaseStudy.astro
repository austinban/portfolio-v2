---
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  role: string;
  year: string;
  tags: string[];
  slug: string;
}

const { title, description, role, year, tags, slug } = Astro.props;

const ogTitle = `${title} — Austin Ban`;
const ogDescription = description;

const caseStudySchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: title,
  description,
  url: `https://austinban.com/work/${slug}`,
  author: {
    "@type": "Person",
    name: "Austin Ban",
    url: "https://austinban.com",
  },
  dateCreated: year,
  keywords: tags.join(", "),
};
---

<Base
  title={ogTitle}
  description={ogDescription}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={`/og/work/${slug}.png`}
  ogType="article"
  schema={caseStudySchema}
>
  <div class="bg-dark text-cream min-h-screen font-sans">

    <main class="mx-auto max-w-3xl px-8 pt-32 pb-24 md:px-20">
      <div class="mb-6 flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <span class="text-muted border-muted/30 border px-3 py-1 text-xs tracking-widest uppercase">
              {tag}
            </span>
          ))
        }
      </div>

      <h1 class="text-cream mb-4 text-5xl leading-none font-bold md:text-7xl">
        {title}
      </h1>
      <p class="text-muted mb-2 text-xl font-light">{description}</p>
      <p class="text-muted/60 mb-16 text-sm tracking-widest uppercase">
        Role: {role}
      </p>

      <div class="prose-custom">
        <slot />
      </div>
    </main>
  </div>
</Base>

<style>
  .prose-custom :global(h2) {
    margin-top: 3rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    color: #7a7060;
    font-weight: 700;
  }

  .prose-custom :global(p) {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #a09880;
    margin-bottom: 1.25rem;
    font-weight: 300;
  }
</style>
